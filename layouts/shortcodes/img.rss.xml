{{- $imgData := (partial "data/img-data.html" .) -}}
{{- $wrapperClass := .Get "class" -}}
{{- with .Inner }}{{- $.Scratch.Set "Inner" . -}}{{ end -}}

{{- if $imgData.data -}}
{{- $d := $imgData.data -}}
<figure>
  <img
    src="{{ $d.src }}"
    width="{{ $d.displayWidth }}"
    height="{{ $d.displayHeight }}"
    alt="{{ $d.alt_description | default `Image for post` }}"
    />
  {{ partial "figcaption.html" . }}
</figure>
{{ end }}